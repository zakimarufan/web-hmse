# <IfModule mod_rewrite.c>
# RewriteEngine On
# RewriteBase /web-hmse/
# RewriteCond %{THE_REQUEST} /index\.php [NC]
# RewriteRule ^(.*?)index\.php$ $1 [L,R=302,NC,NE]
# RewriteRule ^index\.php$ - [L]
